# Frontend environment configuration
# Copy this file to .env.local and fill in the values

# Backend API URL
VITE_API_URL=http://localhost:8080

# Yandex SmartCaptcha site key (for registration form)
# Get from https://yandex.cloud/ru/services/smartcaptcha
VITE_SMARTCAPTCHA_SITE_KEY="ysc1_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Operator personal data (set in .env.local, not committed)
VITE_OPERATOR_NAME="Иванов Иван Иванович"
VITE_OPERATOR_EMAIL="your@email.ru"
