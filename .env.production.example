# BookStrata — Frontend Production Environment
# Copy to .env.production before building for production

# Backend API URL (может быть пустым, если статика и API на одном домене)
VITE_API_URL=""

# Yandex SmartCaptcha — site key для production (отдельный от dev!)
# https://yandex.cloud/ru/services/smartcaptcha
VITE_SMARTCAPTCHA_SITE_KEY="ysc1_production_key_here"

# Yandex Metrica — ID счётчика (необязательно)
VITE_YM_COUNTER_ID="12345678"

# Sentry DSN — мониторинг ошибок (необязательно, но настоятельно рекомендуется)
# Получить: https://sentry.io/signup/
VITE_SENTRY_DSN="https://your-dsn@sentry.io/your-project"

# ФИО и email оператора персональных данных (152-ФЗ)
VITE_OPERATOR_NAME="Пасяда Федор Иванович"
VITE_OPERATOR_EMAIL="fedorpasyada@yandex.ru"
