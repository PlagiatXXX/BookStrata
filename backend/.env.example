# Backend environment configuration
# Copy this file to .env and fill in the values

# PostgreSQL database connection string
DATABASE_URL="postgresql://user:password@localhost:5432/tiermaker_db?schema=public"

# Frontend client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Server port
PORT=8080

# Node environment
NODE_ENV="development"

# JWT secret key (generate a strong random string)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Image storage provider: "cloudinary" (default), "s3", "yandex", or "local"
STORAGE_PROVIDER="cloudinary"

# Cloudinary URL for image hosting (used when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# === OR use S3-compatible storage (Timeweb Cloud, Yandex Object Storage, VK Cloud, etc.) ===
# Set STORAGE_PROVIDER=s3 (or yandex for backward compatibility) and configure below:
# Bucket name
S3_BUCKET="bookstrata-images"
# S3 endpoint (e.g., https://s3.timeweb.com, https://storage.yandexcloud.net)
S3_ENDPOINT="https://storage.yandexcloud.net"
# Region (default: ru-central1)
S3_REGION="ru-central1"
# Static access key
S3_ACCESS_KEY_ID="your-access-key"
# Secret access key
S3_SECRET_ACCESS_KEY="your-secret-key"
# Public host for generating URLs (default: storage.yandexcloud.net)
S3_PUBLIC_HOST="storage.yandexcloud.net"

# === OR use local filesystem storage ===
# Set STORAGE_PROVIDER=local to save images on the server's disk
# Images are served via @fastify/static at /uploads/
# UPLOADS_DIR="uploads"          # relative to project root
# UPLOADS_BASE_URL="/uploads"    # URL prefix for uploaded files
# HuggingFace API key for AI features (optional)
HUGGINGFACE_API_KEY="your-huggingface-api-key"
# Pollinations API key for AI features (REQUIRED for new gen.pollinations.ai API)
# Get your key from https://gen.pollinations.ai
POLLINATIONS_API_KEY="your-pollinations-api-key"
# Pollinations model for avatar generation (default: flux)
# Options: flux, zimage
POLLINATIONS_MODEL="zimage"
# Google Books API key for book search
GOOGLE_BOOKS_API_KEY="your-google-books-api-key"
# === AI Librarian — Primary Provider (Custom) ===
# Your custom OpenAI-compatible API (e.g., neuraldeep.ru, local LLM)
CUSTOM_AI_API_KEY="your-custom-ai-api-key"
# Base URL (default: https://api.neuraldeep.ru/v1)
CUSTOM_AI_BASE_URL=https://api.neuraldeep.ru/v1
# Model name (default: gpt-oss-120b)
CUSTOM_AI_MODEL=gpt-oss-120b

# === AI Librarian — Fallback Provider (OpenRouter) ===
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY="your-openrouter-api-key"
# Model name (default: openai/gpt-4o-mini)
# See available models: https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-4o-mini

# === Telegram Notifications (Error Tracking) ===
# Get bot token from @BotFather in Telegram
TELEGRAM_BOT_TOKEN="SECRET"
# Your Telegram user ID (get from @userinfobot)
TELEGRAM_CHAT_ID="SECRET"
# Enable/disable notifications (true/false)
TELEGRAM_NOTIFICATIONS_ENABLED=false

# Secret password for confirming role changes in admin panel
# Set this to any password you want to use as confirmation
# Leave empty to disable password confirmation
ADMIN_ROLE_CHANGE_SECRET="your-secret-password-for-role-changes"

# === Logging ===
# Directory for log files (production only)
LOG_DIR=/var/log/tiermaker

# === SMTP Configuration (Email) ===
# SMTP host (e.g., smtp.gmail.com, smtp.mailtrap.io)
SMTP_HOST="smtp.mailtrap.io"
# SMTP port (e.g., 587 for TLS, 465 for SSL)
SMTP_PORT=465
# SMTP user (your email or username)
SMTP_USER="Secret"
# SMTP password (your app-specific password or token)
SMTP_PASS="Secret"
# Use SSL/TLS (true/false)
SMTP_SECURE=false
# From email address (e.g., "BookStrata Pro" <noreply@bookstrata.pro>)
SMTP_FROM='"BookStrata Pro" <noreply@bookstrata.pro>'

# === Seed Admin/Moderator Accounts ===
# Данные для seed.ts (npx prisma db seed)
# Укажите email, username и пароль для админов и модераторов
SEED_ADMIN1_EMAIL=""
SEED_ADMIN1_USERNAME=""
SEED_ADMIN1_PASSWORD=""
SEED_ADMIN2_EMAIL=""
SEED_ADMIN2_USERNAME=""
SEED_ADMIN2_PASSWORD=""
SEED_MOD1_EMAIL=""
SEED_MOD1_USERNAME=""
SEED_MOD1_PASSWORD=""
SEED_MOD2_EMAIL=""
SEED_MOD2_USERNAME=""
SEED_MOD2_PASSWORD=""

# === Sentry (Error Tracking) ===
# Get your DSN from https://sentry.io/settings/YOUR_PROJECT/keys/
SENTRY_DSN="https://your-dsn@sentry.io/your-project"

# === Yandex SmartCaptcha ===
# Get your keys from https://yandex.cloud/ru/services/smartcaptcha
SMARTCAPTCHA_SECRET_KEY="ysc2_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# === OAuth: VK ===
# Get your app ID and secret from https://dev.vk.com
VK_CLIENT_ID="your-vk-app-id"
VK_CLIENT_SECRET="your-vk-app-secret"

# === OAuth: Google ===
# Get your credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"