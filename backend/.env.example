# Backend environment configuration
# Copy this file to .env and fill in the values

# PostgreSQL database connection string
DATABASE_URL="postgresql://user:password@localhost:5432/tiermaker_db?schema=public"

# Frontend client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Server port
PORT=8080

# Node environment
NODE_ENV="development"

# JWT secret key (generate a strong random string)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Cloudinary URL for image hosting
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# HuggingFace API key for AI features (optional)
HUGGINGFACE_API_KEY="your-huggingface-api-key"

# Pollinations API key for AI features (REQUIRED for new gen.pollinations.ai API)
# Get your key from https://gen.pollinations.ai
POLLINATIONS_API_KEY="your-pollinations-api-key"

# Pollinations model for avatar generation (default: flux)
# Options: flux, zimage
POLLINATIONS_MODEL="zimage"

# Google Books API key for book search
GOOGLE_BOOKS_API_KEY="your-google-books-api-key"

# === Telegram Notifications (Error Tracking) ===
# Get bot token from @BotFather in Telegram
TELEGRAM_BOT_TOKEN="SECRET"
# Your Telegram user ID (get from @userinfobot)
TELEGRAM_CHAT_ID="SECRET"
# Enable/disable notifications (true/false)
TELEGRAM_NOTIFICATIONS_ENABLED=false

# Secret password for confirming role changes in admin panel
# Set this to any password you want to use as confirmation
# Leave empty to disable password confirmation
ADMIN_ROLE_CHANGE_SECRET="your-secret-password-for-role-changes"

# === Logging ===
# Directory for log files (production only)
LOG_DIR=/var/log/tiermaker

# === SMTP Configuration (Email) ===
# SMTP host (e.g., smtp.gmail.com, smtp.mailtrap.io)
SMTP_HOST="smtp.mailtrap.io"
# SMTP port (e.g., 587 for TLS, 465 for SSL)
SMTP_PORT=465
# SMTP user (your email or username)
SMTP_USER="Secret"
# SMTP password (your app-specific password or token)
SMTP_PASS="Secret"
# Use SSL/TLS (true/false)
SMTP_SECURE=false
# From email address (e.g., "BookStrata Pro" <noreply@bookstrata.pro>)
SMTP_FROM='"BookStrata Pro" <noreply@bookstrata.pro>'
