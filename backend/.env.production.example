# BookStrata — Backend Production Environment
# Copy to .env on the production server
# WARNING: Никогда не коммитить этот файл с реальными секретами!

# === Обязательные ===
DATABASE_URL="postgresql://bookstrata:strong_password@localhost:5432/bookstrata?connection_limit=20"
CLIENT_URL="https://bookstrata.ru"
PORT=8080
NODE_ENV="production"
JWT_SECRET="сгенерировать: openssl rand -hex 64"

# === Хранилище изображений ===
STORAGE_PROVIDER="cloudinary"
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# Если Yandex Object Storage:
# STORAGE_PROVIDER="yandex"
# YC_BUCKET="bookstrata-images"
# YC_BACKUP_BUCKET="bookstrata-backups"
# YC_ENDPOINT="https://storage.yandexcloud.net"
# YC_REGION="ru-central1"
# YC_ACCESS_KEY_ID="..."
# YC_SECRET_ACCESS_KEY="..."
# YC_PUBLIC_HOST="cdn.bookstrata.ru"

# === Яндекс.SmartCaptcha ===
SMARTCAPTCHA_SECRET_KEY="ysc2_production_key_here"

# === Sentry (мониторинг ошибок) ===
# Получить DSN на https://sentry.io (бесплатный tier — 5k events/мес)
SENTRY_DSN="https://key@oXXXX.ingest.sentry.io/XXXXX"

# === Redis ===
REDIS_URL="redis://localhost:6379"

# === AI Librarian ===
CUSTOM_AI_API_KEY="..."
CUSTOM_AI_BASE_URL="https://api.neuraldeep.ru/v1"
CUSTOM_AI_MODEL="gpt-oss-120b"
GEMINI_API_KEY="..."
GEMINI_MODEL="gemini-2.5-flash"
GROQ_API_KEY="..."
GROQ_MODEL="llama-3.1-8b-instant"

# === Прочие API ===
GOOGLE_BOOKS_API_KEY="..."
POLLINATIONS_API_KEY="..."
POLLINATIONS_MODEL="zimage"
HUGGINGFACE_API_KEY="..."

# === Уведомления об ошибках (email) ===
# На какой email слать алерты (по умолчанию — SMTP_USER)
ERROR_NOTIFY_EMAIL="fedorpasyada@yandex.ru"

# === SMTP (Email: верификация, сброс пароля) ===
SMTP_HOST="smtp.yandex.ru"
SMTP_PORT=465
SMTP_USER="fedorpasyada@yandex.ru"
SMTP_PASS="..."
SMTP_SECURE=true
SMTP_FROM='"BookStrata Pro" <fedorpasyada@yandex.ru>'

# === OAuth ===
VK_CLIENT_ID="..."
VK_CLIENT_SECRET="..."
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

# === Админка ===
ADMIN_ROLE_CHANGE_SECRET="..."

# === Rate Limiting (задать явно для production) ===
RATE_LIMIT_MAX=200

# === Seed (только для первого деплоя) ===
SEED_ADMIN1_EMAIL="..."
SEED_ADMIN1_USERNAME="..."
SEED_ADMIN1_PASSWORD="..."
